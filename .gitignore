## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Original source: https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
*.pidb

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Release]/
x64/
x86/
[AR]M/
[AR]M64/
bld/
[Bin]/
[Ob]ject/
[Log]/
[Logs]/

# Visual Studio 2015/2017/2019/2022 cache directory
.vs/
# Uncomment if you have tasks that create the project's static files in wwwroot
#wwwroot/

# Compiled files
*.dll
*.exe
*.pdb
*.executable

# MSTest test Results
[T]est[R]esult*/
[B]uild[L]og.*

# NUNIT
*.VisualState.xml
TestResult.xml

# Build Office Add-ins
~*

# ReSharper is a dirty blocker of writing files, but he is cool
_ReSharper*/
*.[Re]Sharper
*.DotSettings.user

# JustCode Analysis Auto-generated Source Files
[J]ust[C]ode[P]roject[L]ist.xml
[J]ust[C]ode[A]nalysis[C]onfig.xml

# TeamCity is a build server and he writes files
_TeamCity*

# DotCover is a Code Coverage Tool
*.dotCover

# AxoCover code coverage values
.axoCover/*
!.axoCover/settings.json

# Coverlet code coverage results
coverage.json

# Visual Studio Code project settings
.vscode/

# Rider project settings
.idea/

# Archives
*.zip
*.tar.gz
*.rar

# Operating System Files
Thumbs.db
ehthumbs.db
Desktop.ini

# dotnet publish output
publish/

# BenchmarkDotNet artifacts
BenchmarkDotNet.Artifacts/

# NuGet Packages
*.nupkg
# NuGet Restore NuGet.Config local packages directory
# pkgs/

# Local History for Visual Studio Code
.history/

# BlueJ files
*.class

# Log files
*.log
*.log.*
stdout.txt
stderr.txt

# Crash dumps
*.dmp

# Python cache
__pycache__/
*.pyc

# Rider
*.sln.iml

# MSBuild
bin/
obj/ 

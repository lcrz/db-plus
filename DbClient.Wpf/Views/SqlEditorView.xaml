<UserControl x:Class="DbClient.Wpf.Views.SqlEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
             xmlns:helpers="clr-namespace:DbClient.Wpf.Helpers"
             xmlns:vm="clr-namespace:DbClient.Wpf.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="800"
             DataContextChanged="UserControl_DataContextChanged">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <Style x:Key="ModernToggleButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#353535"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                                <Setter Property="Cursor" Value="No"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo para cada pestaña (TabItem) de la barra de pestañas -->
        <Style x:Key="SqlQueryTabItemStyle" TargetType="TabItem" BasedOn="{StaticResource ModernTabItem}">
            <Setter Property="Header" Value="{Binding Title}"/>
            <Setter Property="AllowDrop" Value="True"/>
            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TabControl}}"/>
            <Setter Property="ContextMenu">
                <Setter.Value>
                    <ContextMenu Style="{StaticResource ModernContextMenu}">
                        <MenuItem Header="Cerrar pestaña" 
                                   Command="{Binding PlacementTarget.Tag.CloseTabCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                   CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                   Style="{StaticResource ModernMenuItem}"/>
                        <MenuItem Header="Cerrar otras pestañas" 
                                   Command="{Binding PlacementTarget.Tag.CloseOtherTabsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                   CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                   Style="{StaticResource ModernMenuItem}"/>
                        <MenuItem Header="Cerrar pestañas a la derecha" 
                                   Command="{Binding PlacementTarget.Tag.CloseTabsToTheRightCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                   CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                   Style="{StaticResource ModernMenuItem}"/>
                        <Separator Style="{StaticResource ModernMenuSeparator}"/>
                        <MenuItem Header="Cerrar todas las pestañas" 
                                   Command="{Binding PlacementTarget.Tag.CloseAllTabsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                   Style="{StaticResource ModernMenuItem}"/>
                    </ContextMenu>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="0,0,1,2" 
                                CornerRadius="3,3,0,0"
                                Padding="12,6"
                                Margin="0,0,2,0"
                                SnapsToDevicePixels="True">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="⚡" Margin="0,0,6,0" Foreground="{StaticResource AccentLightBrush}" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Title}" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                                <Button x:Name="closeButton" 
                                        Content="✕" 
                                        Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=TabControl}}" 
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource TabCloseButtonStyle}"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="border" Property="Background" Value="#1E1E1E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource ContentBackgroundBrush}">
        <Grid.RowDefinitions>
            <!-- Tab Headers Bar -->
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="Auto"/>
            <!-- Editor (AvalonEdit) -->
            <RowDefinition Height="*" MinHeight="100"/>
            <!-- Splitter -->
            <RowDefinition Height="4"/>
            <!-- Resultados (DataGrid) -->
            <RowDefinition Height="1.2*" MinHeight="100"/>
        </Grid.RowDefinitions>

        <!-- Tab Headers and Add Button -->
        <Grid Grid.Row="0" Background="#181818">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TabControl Name="tabControl" 
                        Grid.Column="0" 
                        ItemsSource="{Binding Tabs}" 
                        SelectedItem="{Binding SelectedTab}" 
                        Style="{StaticResource TabStripStyle}"
                        ItemContainerStyle="{StaticResource SqlQueryTabItemStyle}"
                        SelectionChanged="TabControl_SelectionChanged"
                        PreviewMouseLeftButtonDown="TabControl_PreviewMouseLeftButtonDown"
                        PreviewMouseMove="TabControl_PreviewMouseMove"
                        Drop="TabControl_Drop"
                        AllowDrop="True"
                        BorderThickness="0"/>
            
            <Button Grid.Column="1" 
                    Content="➕" 
                    Command="{Binding NewTabCommand}" 
                    Style="{StaticResource ModernButton}" 
                    Margin="4,2" 
                    Padding="6,2" 
                    Height="24"
                    Width="28"
                    FontSize="11" 
                    VerticalAlignment="Center"/>
        </Grid>

        <!-- SQL Toolbar -->
        <Border Grid.Row="1" Background="#1E1E1E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="▶ Ejecutar (F5)" Click="ExecuteButton_Click" Style="{StaticResource AccentButton}" Padding="15,6" Height="30" FontSize="12"/>
                    <Button Content="💾 Guardar Consulta" Command="{Binding ShowSaveQueryDialogCommand}" Style="{StaticResource ModernButton}" Padding="15,6" Height="30" FontSize="12" Margin="10,0,0,0"/>
                    <TextBlock Text="{Binding SelectedTab.ExecutionTimeMessage}" Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center" Margin="15,0,0,0" FontWeight="SemiBold"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding SelectedTab.StatusMessage}" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab.HasError}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Editor Principal y Panel IA -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Editor de Consulta AvalonEdit -->
            <avalonedit:TextEditor Name="textEditor"
                                   Grid.Column="0"
                                   ShowLineNumbers="True"
                                   FontFamily="Consolas, Courier New, monospace"
                                   FontSize="14"
                                   Background="#151515"
                                   Foreground="{StaticResource TextBrush}"
                                   LineNumbersForeground="#555555"
                                   Padding="10"
                                   PreviewKeyDown="textEditor_PreviewKeyDown">
                <avalonedit:TextEditor.ContextMenu>
                    <ContextMenu Style="{StaticResource ModernContextMenu}" Opened="ContextMenu_Opened">
                        <MenuItem x:Name="menuItemFormatSelection" Header="Dar formato a la selección" Click="FormatSelection_Click" Style="{StaticResource ModernMenuItem}"/>
                        <MenuItem Header="Dar formato a todo" Click="FormatAll_Click" Style="{StaticResource ModernMenuItem}"/>
                        <Separator Style="{StaticResource ModernMenuSeparator}"/>
                        <MenuItem Header="Cortar" Command="Cut" Style="{StaticResource ModernMenuItem}"/>
                        <MenuItem Header="Copiar" Command="Copy" Style="{StaticResource ModernMenuItem}"/>
                        <MenuItem Header="Pegar" Command="Paste" Style="{StaticResource ModernMenuItem}"/>
                    </ContextMenu>
                </avalonedit:TextEditor.ContextMenu>
            </avalonedit:TextEditor>

            <!-- Separador Vertical -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="{StaticResource BorderBrush}"/>

            <!-- Panel de Inteligencia Artificial -->
            <Border Grid.Column="2" Background="#1A1A1A" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="✨ Asistente IA (Ollama)" Foreground="{StaticResource AccentLightBrush}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10"/>
                    
                    <TextBlock Grid.Row="1" Text="¿Qué consulta deseas generar?" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,5"/>
                    <TextBox Grid.Row="2" Text="{Binding AiPrompt, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" Background="#252526" Foreground="White" BorderBrush="{StaticResource BorderBrush}" Padding="5" MinHeight="80"/>

                    <Grid Grid.Row="3" Margin="0,10,0,10">
                        <Button Content="Generar Consulta" Command="{Binding GenerateSqlCommand}" Height="34" Padding="12,4">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ModernButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGeneratingSql}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGeneratingSql}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="⏳ Generando..." Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBox Grid.Row="0" Text="{Binding AiGeneratedSql}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" Background="#151515" Foreground="#8FEF8F" FontFamily="Consolas" BorderBrush="{StaticResource BorderBrush}" Padding="5" MinHeight="100" MaxHeight="200" VerticalScrollBarVisibility="Auto"/>
                        <Button Grid.Row="1" Content="Insertar en el Editor" Command="{Binding InsertSqlToEditorCommand}" Style="{StaticResource AccentButton}" Margin="0,10,0,0" Height="34" Padding="12,4"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Separador Horizontal -->
        <GridSplitter Grid.Row="3" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Background="{StaticResource BorderBrush}"/>

        <!-- Panel de Resultados -->
        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#252526" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Resultados de la Consulta" Foreground="{StaticResource TextMutedBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <ToggleButton Grid.Column="1" 
                                  Content="📋 Ver JSON" 
                                  IsChecked="{Binding SelectedTab.SelectedQueryResult.IsJsonPanelVisible}"
                                  Style="{StaticResource ModernToggleButton}"
                                  Visibility="{Binding SelectedTab.SelectedQueryResult.IsTable, Converter={StaticResource BoolToVis}}"
                                  Padding="8,4"
                                  FontSize="11"/>
                </Grid>
            </Border>

            <!-- TabControl de resultados -->
            <TabControl Grid.Row="1" 
                        ItemsSource="{Binding SelectedTab.QueryResultsList}" 
                        SelectedItem="{Binding SelectedTab.SelectedQueryResult}"
                        Style="{StaticResource TabStripWithContentStyle}"
                        BorderThickness="0"
                        Background="#1E1E1E">
                <TabControl.ItemContainerStyle>
                    <Style TargetType="TabItem" BasedOn="{StaticResource ModernTabItem}">
                        <Setter Property="HeaderTemplate">
                            <Setter.Value>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <Button Content="↗" 
                                                Command="{Binding DetachCommand}"
                                                ToolTip="Desacoplar resultado en ventana flotante"
                                                Style="{StaticResource TabCloseButtonStyle}"
                                                Foreground="{StaticResource AccentLightBrush}"
                                                VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.ItemContainerStyle>
                <TabControl.ContentTemplate>
                    <DataTemplate>
                        <Grid Background="#151515">
                            <!-- Si es una tabla, mostramos el DataGrid -->
                            <Grid>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTable}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="300">
                                        <ColumnDefinition.Style>
                                            <Style TargetType="ColumnDefinition">
                                                <Setter Property="MinWidth" Value="150"/>
                                                <Setter Property="MaxWidth" Value="600"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsJsonPanelVisible}" Value="False">
                                                        <Setter Property="MinWidth" Value="0"/>
                                                        <Setter Property="MaxWidth" Value="0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ColumnDefinition.Style>
                                    </ColumnDefinition>
                                </Grid.ColumnDefinitions>

                                <DataGrid Grid.Column="0"
                                          helpers:DataGridExtensions.BindableSource="{Binding DataTable}"
                                          SelectedItem="{Binding SelectedRow}"
                                          Style="{StaticResource ModernDataGrid}"
                                          IsReadOnly="True"
                                          AutoGenerateColumns="True">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Copiar como SQL" 
                                                      Command="{Binding CopyAsSqlCommand}" 
                                                      CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="Copiar como Json" 
                                                      Command="{Binding CopyAsJsonCommand}" 
                                                      CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            <MenuItem Header="Copiar como CSV" 
                                                      Command="{Binding CopyAsCsvCommand}" 
                                                      CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                </DataGrid>

                                <!-- Separador para el panel JSON -->
                                <GridSplitter Grid.Column="1" 
                                              Width="4" 
                                              HorizontalAlignment="Stretch" 
                                              VerticalAlignment="Stretch" 
                                              Background="{StaticResource BorderBrush}"
                                              Visibility="{Binding IsJsonPanelVisible, Converter={StaticResource BoolToVis}}"/>

                                <!-- Panel de Detalles JSON -->
                                <Grid Grid.Column="2" 
                                      HorizontalAlignment="Stretch"
                                      Background="#161616" 
                                      Margin="0"
                                      Visibility="{Binding IsJsonPanelVisible, Converter={StaticResource BoolToVis}}">
                                    <Grid.RowDefinitions>
                                        <!-- Filtro TextBox -->
                                        <RowDefinition Height="Auto"/>
                                        <!-- TreeView de JSON -->
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Campo de Filtrado de Propiedades -->
                                    <Border Grid.Row="0" Background="#1E1E1E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10">
                                        <StackPanel>
                                            <TextBlock Text="Filtrar Propiedades" Style="{StaticResource ModernLabel}" Margin="0,0,0,3"/>
                                            <TextBox Text="{Binding JsonFilterText, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource ModernTextBox}"
                                                     Padding="8,6"
                                                     Height="32"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- TreeView de Detalles JSON -->
                                    <TreeView Grid.Row="1" 
                                              ItemsSource="{Binding JsonNodes}" 
                                              Style="{StaticResource ModernTreeView}" 
                                              BorderThickness="0" 
                                              Padding="10"
                                              KeyDown="TreeView_KeyDown">
                                        <TreeView.ItemContainerStyle>
                                            <Style TargetType="TreeViewItem">
                                                <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BoolToVis}}"/>
                                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                                <Style.Resources>
                                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2D2D30"/>
                                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#E5E5E5"/>
                                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#1F1F1F"/>
                                                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#E5E5E5"/>
                                                </Style.Resources>
                                            </Style>
                                        </TreeView.ItemContainerStyle>
                                        <TreeView.Resources>
                                            <HierarchicalDataTemplate DataType="{x:Type vm:JsonNodeViewModel}" ItemsSource="{Binding Children}">
                                                <StackPanel Orientation="Horizontal" Margin="2,1" Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}">
                                                    <StackPanel.ContextMenu>
                                                        <ContextMenu Style="{StaticResource ModernContextMenu}">
                                                            <MenuItem Header="Copiar solo key" 
                                                                      Command="{Binding PlacementTarget.Tag.CopyNodeKeyCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                            <MenuItem Header="Copiar key + valor (JSON)" 
                                                                      Command="{Binding PlacementTarget.Tag.CopyNodeKeyAndValueCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                            <MenuItem Header="Copiar key + sub-nodos (JSON)" 
                                                                      Command="{Binding PlacementTarget.Tag.CopyNodeKeyAndSubtreeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        </ContextMenu>
                                                    </StackPanel.ContextMenu>
                                                    <TextBlock x:Name="IconText" Text="📄" Margin="0,0,6,0" VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                                    <TextBlock Text="{Binding Key}" FontWeight="SemiBold" Foreground="#4D9CE4" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="SeparatorText" Text=": " Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="ValueText" Text="{Binding Value}" Foreground="#2ECC71" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="250" Visibility="Visible"/>
                                                    <TextBox x:Name="ValueEdit" 
                                                             Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" 
                                                             Foreground="#2ECC71" 
                                                             Background="#1F1F1F" 
                                                             BorderBrush="#333333" 
                                                             BorderThickness="1" 
                                                             Padding="4,2" 
                                                             Margin="2,0" 
                                                             VerticalAlignment="Center" 
                                                             TextWrapping="Wrap" 
                                                             MaxWidth="250" 
                                                             CaretBrush="#2ECC71"
                                                             Visibility="Collapsed"/>
                                                </StackPanel>
                                                <HierarchicalDataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsObject}" Value="True">
                                                        <Setter TargetName="IconText" Property="Text" Value="🔸"/>
                                                        <Setter TargetName="IconText" Property="Foreground" Value="#9B5DE5"/>
                                                        <Setter TargetName="SeparatorText" Property="Visibility" Value="Collapsed"/>
                                                        <Setter TargetName="ValueText" Property="Visibility" Value="Collapsed"/>
                                                        <Setter TargetName="ValueEdit" Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsEditable}" Value="True">
                                                        <Setter TargetName="ValueText" Property="Visibility" Value="Collapsed"/>
                                                        <Setter TargetName="ValueEdit" Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Value}" Value="{x:Null}">
                                                        <Setter TargetName="ValueText" Property="Text" Value="null"/>
                                                        <Setter TargetName="ValueText" Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                                        <Setter TargetName="ValueText" Property="FontStyle" Value="Italic"/>
                                                    </DataTrigger>
                                                </HierarchicalDataTemplate.Triggers>
                                            </HierarchicalDataTemplate>
                                        </TreeView.Resources>
                                    </TreeView>
                                </Grid>
                            </Grid>

                            <!-- Si es un mensaje de filas afectadas, lo mostramos bonito -->
                            <Border Padding="20">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTable}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                                    <TextBlock Text="✔️" FontSize="16" Margin="0,0,10,0" Foreground="{StaticResource SuccessBrush}"/>
                                    <TextBlock Text="{Binding Message}" FontSize="14" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>

            <!-- Panel de error de ejecución -->
            <Border Grid.Row="1" Background="#2A1515" BorderBrush="{StaticResource ErrorBrush}" BorderThickness="0,1,0,0" Padding="15">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedTab.HasError}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="⚠️ Error de Ejecución SQL" Foreground="{StaticResource ErrorBrush}" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding SelectedTab.ErrorMessage}" Foreground="#FFAAAA" TextWrapping="Wrap" FontFamily="Consolas" FontSize="13" LineHeight="18"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Dialogo Modal para Guardar Consulta -->
        <Grid Grid.Row="0" Grid.RowSpan="5" Background="#80000000" Focusable="True">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSaveQueryDialogOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Background="#252526" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="5" Width="360" Height="180" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Guardar Consulta SQL" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                    
                    <StackPanel Grid.Row="1">
                        <TextBlock Text="Nombre de la consulta:" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" FontSize="12"/>
                        <TextBox Text="{Binding NewQueryName, UpdateSourceTrigger=PropertyChanged}" Background="#1E1E1E" Foreground="White" BorderBrush="{StaticResource BorderBrush}" Padding="6,4" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="Guardar" Command="{Binding SaveActiveQueryCommand}" Style="{StaticResource AccentButton}" Padding="12,5" Margin="0,0,10,0"/>
                        <Button Content="Cancelar" Command="{Binding CloseSaveQueryDialogCommand}" Style="{StaticResource ModernButton}" Padding="12,5"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

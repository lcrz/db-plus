<UserControl x:Class="DbClient.Wpf.Views.ErDiagramView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DbClient.Wpf.Views"
             xmlns:vm="clr-namespace:DbClient.Wpf.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000"
             Background="{StaticResource ContentBackgroundBrush}">

    <UserControl.Resources>
        <!-- Spacers and Separators -->
        <Style x:Key="ToolbarSeparator" TargetType="Separator">
            <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Width" Value="1"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Margin" Value="10,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Top Toolbar -->
            <RowDefinition Height="Auto"/>
            <!-- Diagram Area (Sidebar + Splitter + Canvas) -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Toolbar -->
        <Border Grid.Row="0" Background="{StaticResource SidebarBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Buttons -->
                    <ColumnDefinition Width="*"/>    <!-- Spacer / Status -->
                    <ColumnDefinition Width="Auto"/> <!-- Search -->
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="⟳ Cargar Diagrama" 
                            Command="{Binding LoadDiagramCommand}" 
                            Style="{StaticResource ModernButton}" 
                            Padding="12,6" 
                            Margin="0,0,8,0"
                            ToolTip="Cargar/Actualizar esquema de la base de datos"/>

                    <Button Content="🧩 Auto-distribuir" 
                            Command="{Binding AutoLayoutCommand}" 
                            Style="{StaticResource ModernButton}" 
                            Padding="12,6" 
                            Margin="0,0,8,0"
                            ToolTip="Organizar tablas visibles en cuadrícula"/>

                    <Separator Style="{StaticResource ToolbarSeparator}"/>

                    <Button Content="➕" 
                            Command="{Binding ZoomInCommand}" 
                            Style="{StaticResource ModernButton}" 
                            Padding="8,6" 
                            ToolTip="Acercar"/>

                    <TextBlock Text="{Binding ZoomScale, StringFormat={}{0:P0}}" 
                               VerticalAlignment="Center" 
                               Margin="8,0" 
                               Foreground="{StaticResource TextMutedBrush}" 
                               FontWeight="SemiBold"
                               Width="45"
                               TextAlignment="Center"/>

                    <Button Content="➖" 
                            Command="{Binding ZoomOutCommand}" 
                            Style="{StaticResource ModernButton}" 
                            Padding="8,6" 
                            ToolTip="Alejar"/>

                    <Button Content="🔍 1:1" 
                            Command="{Binding ResetZoomCommand}" 
                            Style="{StaticResource ModernButton}" 
                            Padding="8,6" 
                            Margin="8,0,0,0"
                            ToolTip="Restablecer escala"/>

                    <Separator Style="{StaticResource ToolbarSeparator}"/>

                    <Button Content="💾 Exportar Imagen" 
                            Click="ExportImage_Click"
                            Style="{StaticResource ModernButton}" 
                            Padding="12,6"
                            ToolTip="Exportar diagrama completo como imagen PNG"/>
                </StackPanel>

                <!-- Indicator for Loading -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" x:Name="loadingIndicator">
                    <TextBlock Text="⌛" FontSize="14" Margin="0,0,8,0"/>
                    <TextBlock Text="Cargando esquema de la base de datos..." Foreground="{StaticResource AccentLightBrush}" FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Search/Highlight Box in Canvas -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Resaltar Tabla:" Style="{StaticResource ModernLabel}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource ModernTextBox}" 
                             Width="180" 
                             Height="28"
                             Padding="8,4"
                             VerticalAlignment="Center"
                             ToolTip="Resaltar tablas en el lienzo"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Diagram Area (Sidebar + Splitter + Canvas) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Left Sidebar checklist -->
                <ColumnDefinition Width="240" MinWidth="180" MaxWidth="400"/>
                <!-- Splitter -->
                <ColumnDefinition Width="4"/>
                <!-- Canvas Area -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 1. Left Sidebar checklist -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0" Padding="12,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Title / List Search -->
                        <RowDefinition Height="Auto"/> <!-- Action Buttons -->
                        <RowDefinition Height="*"/>    <!-- Scrollable Checklist -->
                    </Grid.RowDefinitions>

                    <!-- Title & Sidebar Search -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="TABLAS EN DIAGRAMA" Style="{StaticResource ModernLabel}" FontWeight="Bold" Margin="0,0,0,6" Foreground="{StaticResource TextBrush}"/>
                        <TextBox Text="{Binding TableListSearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource ModernTextBox}"
                                 Height="28"
                                 Padding="8,4"
                                 ToolTip="Filtrar listado lateral para buscar tablas"/>
                    </StackPanel>

                    <!-- Quick toggle buttons -->
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Mostrar todas" Command="{Binding SelectAllTablesCommand}" Style="{StaticResource ModernButton}" Padding="4" Margin="0,0,4,0" FontSize="11" Height="24"/>
                        <Button Grid.Column="1" Content="Ocultar todas" Command="{Binding UnselectAllTablesCommand}" Style="{StaticResource ModernButton}" Padding="4" Margin="4,0,0,0" FontSize="11" Height="24"/>
                    </Grid>

                    <!-- Checklist -->
                    <ScrollViewer Grid.Row="2" ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TablesListView}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4" Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsVisible, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding TableName}" Foreground="{StaticResource TextBrush}" FontSize="12.5" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTip="{Binding TableName}"/>
                                        
                                        <!-- Context Menu on Right Click -->
                                        <Grid.ContextMenu>
                                            <ContextMenu Style="{StaticResource ModernContextMenu}">
                                                <MenuItem Header="Ver solo esta tabla y relacionadas" 
                                                          Command="{Binding PlacementTarget.Tag.ShowOnlyThisAndRelatedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          Style="{StaticResource ModernMenuItem}"/>
                                                <Separator Style="{StaticResource ModernMenuSeparator}"/>
                                                <MenuItem Header="Mostrar/Ocultar campos" 
                                                          Command="{Binding PlacementTarget.Tag.ToggleColumnsVisibilityCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          Style="{StaticResource ModernMenuItem}"/>
                                                <MenuItem Header="Mostrar/Ocultar campos (Todas las tablas)" 
                                                          Command="{Binding PlacementTarget.Tag.ToggleAllColumnsVisibilityCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          Style="{StaticResource ModernMenuItem}"/>
                                            </ContextMenu>
                                        </Grid.ContextMenu>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- 2. GridSplitter -->
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="{StaticResource BorderBrush}"/>

            <!-- 3. Canvas Container -->
            <Border Grid.Column="2" Name="diagramContainer"
                    Background="Transparent"
                    ClipToBounds="True"
                    MouseDown="DiagramContainer_MouseDown"
                    MouseMove="DiagramContainer_MouseMove"
                    MouseUp="DiagramContainer_MouseUp"
                    MouseWheel="DiagramContainer_MouseWheel">

                <Canvas Name="diagramCanvas" Width="10000" Height="10000" HorizontalAlignment="Left" VerticalAlignment="Top">
                    <!-- Zoom & Pan transform -->
                    <Canvas.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="{Binding ZoomScale}" ScaleY="{Binding ZoomScale}"/>
                            <TranslateTransform X="{Binding PanX}" Y="{Binding PanY}"/>
                        </TransformGroup>
                    </Canvas.RenderTransform>

                    <!-- Infinite Grid Background -->
                    <Canvas.Background>
                        <VisualBrush TileMode="Tile" Viewport="0,0,25,25" ViewportUnits="Absolute">
                            <VisualBrush.Visual>
                                <Grid Width="25" Height="25">
                                    <Path Data="M 0 0 L 0 25 M 0 25 L 25 25" Stroke="#1B1B1B" StrokeThickness="0.8"/>
                                    <Path Data="M 0 0 L 25 0 M 25 0 L 25 25" Stroke="#1B1B1B" StrokeThickness="0.8"/>
                                </Grid>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Canvas.Background>

                    <!-- 1st. Connections Layer (underneath tables) -->
                    <ItemsControl ItemsSource="{Binding Connections}" IsHitTestVisible="False">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Line X1="{Binding StartX}" Y1="{Binding StartY}" 
                                      X2="{Binding EndX}" Y2="{Binding EndY}"
                                      StrokeThickness="2"
                                      Opacity="{Binding Opacity}">
                                    <Line.Style>
                                        <Style TargetType="Line">
                                            <Setter Property="Stroke" Value="{StaticResource AccentLightBrush}"/>
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                    <Setter Property="Stroke" Value="{StaticResource SuccessBrush}"/>
                                                    <Setter Property="StrokeThickness" Value="3"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Line.Style>
                                </Line>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 2nd. Tables Layer -->
                    <ItemsControl ItemsSource="{Binding Tables}" Name="tablesItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X, Mode=TwoWay}"/>
                                <Setter Property="Canvas.Top" Value="{Binding Y, Mode=TwoWay}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Table Card -->
                                <Border Background="#252526" 
                                        BorderThickness="1.5" 
                                        CornerRadius="8" 
                                        Width="{Binding Width}"
                                        Opacity="{Binding Opacity}"
                                        Padding="0"
                                        Margin="0"
                                        Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        PreviewMouseLeftButtonDown="TableCard_PreviewMouseLeftButtonDown"
                                        PreviewMouseMove="TableCard_MouseMove"
                                        PreviewMouseLeftButtonUp="TableCard_MouseLeftButtonUp"
                                        Cursor="SizeAll">
                                    
                                    <!-- Context Menu on Right Click -->
                                    <Border.ContextMenu>
                                        <ContextMenu Style="{StaticResource ModernContextMenu}">
                                            <MenuItem Header="Ver solo esta tabla y relacionadas" 
                                                      Command="{Binding PlacementTarget.Tag.ShowOnlyThisAndRelatedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Style="{StaticResource ModernMenuItem}"/>
                                            <Separator Style="{StaticResource ModernMenuSeparator}"/>
                                            <MenuItem Header="Mostrar/Ocultar campos" 
                                                      Command="{Binding PlacementTarget.Tag.ToggleColumnsVisibilityCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Style="{StaticResource ModernMenuItem}"/>
                                            <MenuItem Header="Mostrar/Ocultar campos (Todas las tablas)" 
                                                      Command="{Binding PlacementTarget.Tag.ToggleAllColumnsVisibilityCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      Style="{StaticResource ModernMenuItem}"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>

                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="3" Direction="270" Color="Black" Opacity="0.5"/>
                                    </Border.Effect>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="#333333"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentLightBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <StackPanel>
                                        <!-- Header -->
                                        <Border Background="#1E1E1E" CornerRadius="7,7,0,0" Padding="12,8" BorderThickness="0,0,0,1" BorderBrush="#333333">
                                            <TextBlock Text="{Binding TableName}" 
                                                       FontWeight="Bold" 
                                                       Foreground="White" 
                                                       FontSize="12.5" 
                                                       TextTrimming="CharacterEllipsis"
                                                       HorizontalAlignment="Center"/>
                                        </Border>

                                        <!-- Columns list -->
                                        <ItemsControl ItemsSource="{Binding Columns}" Margin="0,4,0,8">
                                            <ItemsControl.Style>
                                                <Style TargetType="ItemsControl">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding AreColumnsVisible}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ItemsControl.Style>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="12,3" Height="18">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/> <!-- Key Icon -->
                                                            <ColumnDefinition Width="*"/>    <!-- Name -->
                                                            <ColumnDefinition Width="Auto"/> <!-- Type -->
                                                        </Grid.ColumnDefinitions>

                                                        <!-- PK / FK Icons -->
                                                        <StackPanel Orientation="Horizontal" Grid.Column="0" Margin="0,0,6,0">
                                                            <TextBlock Text="🔑" FontSize="9.5" VerticalAlignment="Center" Visibility="Collapsed" x:Name="pkIcon" ToolTip="Primary Key" Foreground="#E1B12C"/>
                                                            <TextBlock Text="🔗" FontSize="9.5" VerticalAlignment="Center" Visibility="Collapsed" x:Name="fkIcon" ToolTip="Foreign Key" Foreground="{StaticResource AccentLightBrush}"/>
                                                        </StackPanel>

                                                        <TextBlock Text="{Binding Name}" 
                                                                   Grid.Column="1" 
                                                                   VerticalAlignment="Center" 
                                                                   Foreground="#E5E5E5" 
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis"/>

                                                        <TextBlock Text="{Binding Type}" 
                                                                   Grid.Column="2" 
                                                                   VerticalAlignment="Center" 
                                                                   Foreground="{StaticResource TextMutedBrush}" 
                                                                   FontSize="10"
                                                                   Margin="8,0,0,0"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </Grid>
                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding IsPrimaryKey}" Value="True">
                                                            <Setter TargetName="pkIcon" Property="Visibility" Value="Visible"/>
                                                            <Setter TargetName="fkIcon" Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsForeignKey}" Value="True">
                                                            <Setter TargetName="fkIcon" Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Canvas>
            </Border>

            <!-- Error message overlay (Spans columns 0 to 2) -->
            <Border Grid.Column="0" Grid.ColumnSpan="3" Background="#CC000000" Visibility="Collapsed" x:Name="errorOverlay" Padding="40">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="500">
                    <TextBlock Text="⚠️ Error al Cargar Diagrama" FontSize="18" FontWeight="Bold" Foreground="{StaticResource ErrorBrush}" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap" LineHeight="20" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,25,0"/>
                    <Button Content="Reintentar Carga" Command="{Binding LoadDiagramCommand}" Style="{StaticResource AccentButton}" Width="150" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Empty database / No tables prompt overlay (Spans columns 0 to 2) -->
            <Border Grid.Column="0" Grid.ColumnSpan="3" Background="#1E1E1E" Visibility="Collapsed" x:Name="emptyOverlay">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="🗺️ Diagrama Entidad Relación" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                    <TextBlock Text="Carga el diagrama para visualizar gráficamente las tablas y sus relaciones." Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,20" HorizontalAlignment="Center"/>
                    <Button Content="Cargar Diagrama" Command="{Binding LoadDiagramCommand}" Style="{StaticResource AccentButton}" Width="185" Height="36" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
